  },
  "ecosystem": {
    "atlas": "https://github.com/ReineiraOS/reineira-atlas",
    "modules": "https://github.com/ReineiraOS/platform-modules",
    "docs": "https://reineira.xyz/docs",
    "sdk": "https://www.npmjs.com/package/@reineira-os/sdk"
